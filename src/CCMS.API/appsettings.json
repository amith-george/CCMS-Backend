{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "",
    "Issuer": "CCMS.API",
    "Audience": "CCMS.Frontend",
    "ExpiryMinutes": 120
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "AzureBlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "ccms-documents"
  }
}